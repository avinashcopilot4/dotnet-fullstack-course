## 🌍 URL & Location

```js
// window.location
location.href          // full URL
location.origin        // "https://example.com"
location.pathname      // "/products/detail"
location.search        // "?id=5&color=red"
location.hash          // "#section2"
location.hostname      // "example.com"

// Navigate
location.href = "https://google.com";  // redirect
location.assign("page.html");          // navigate (adds to history)
location.replace("page.html");         // navigate (NO history entry)
location.reload();                     // refresh page

// URLSearchParams — parse query strings
const params = new URLSearchParams(location.search);
params.get("id");        // "5"
params.get("color");     // "red"
params.has("id");        // true
params.set("page", "2");
params.toString();       // "id=5&color=red&page=2"
```

