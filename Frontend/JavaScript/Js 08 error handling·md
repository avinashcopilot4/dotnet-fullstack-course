## 🎯 Throwing Errors

```js
// Throw any value (but Error objects are best practice)
throw new Error("Something went wrong");
throw new TypeError("Expected a string");
throw new RangeError("Age must be 0–120");

// Throw in a function
function divide(a, b) {
  if (b === 0) throw new Error("Cannot divide by zero");
  return a / b;
}

try {
  divide(10, 0);
} catch (e) {
  console.error(e.message);  // "Cannot divide by zero"
}
```

