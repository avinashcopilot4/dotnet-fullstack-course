## 📋 Working with Forms

### Accessing Form & Fields
```js
const form = document.querySelector("#login-form");

// Access fields by name
form.elements["email"].value
form.elements["password"].value

// Or by querySelector
form.querySelector("#email").value
```

### Reading Input Values
```js
// Text, email, password, number inputs
input.value           // current value (always a string)
input.value.trim()    // remove whitespace

// Checkbox
checkbox.checked      // true / false
checkbox.value        // the value attribute

// Radio buttons
const selected = document.querySelector('input[name="gender"]:checked');
selected?.value       // "male" / "female"

// Select dropdown
select.value          // selected option's value
select.selectedIndex  // index
select.options[select.selectedIndex].text  // display text

// Textarea
textarea.value
```

### Form Submission
```js
const form = document.querySelector("form");

form.addEventListener("submit", (e) => {
  e.preventDefault();  // ALWAYS prevent default first

  const email    = form.querySelector("#email").value.trim();
  const password = form.querySelector("#password").value;

  // Validate
  if (!email) {
    showError("email", "Email is required");
    return;
  }
  if (password.length < 6) {
    showError("password", "Min 6 characters");
    return;
  }

  // Submit to API
  submitLogin({ email, password });
});
```

### Using FormData
```js
form.addEventListener("submit", (e) => {
  e.preventDefault();
  const data = new FormData(form);

  // Access fields
  data.get("email")
  data.get("password")

  // Iterate all fields
  for (const [key, value] of data.entries()) {
    console.log(key, value);
  }

  // Convert to plain object
  const obj = Object.fromEntries(data.entries());

  // Send to API directly (no JSON.stringify needed)
  fetch("/api/login", { method: "POST", body: data });
});
```

